# Normalize text files with LF in repository
* text=auto eol=lf

# Python / config / docs
*.py text eol=lf
*.md text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf
*.txt text eol=lf
*.ps1 text eol=crlf
*.bat text eol=crlf

# Treat binaries correctly
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.docx binary
*.xlsx binary
*.xls binary
*.zip binary
*.7z binary
*.exe binary
*.dll binary
